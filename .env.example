# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# Firebase (frontend — Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase (API / Vercel serverless)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# CORS — comma-separated production origins (no localhost)
ALLOWED_ORIGINS=https://www.biobiocode.cl,https://biobiocode.cl

# Zoho SMTP — para envío de emails de prospección (api/send-email.js)
# Crear una App Password en: https://accounts.zoho.com/home#security/app-password
ZOHO_EMAIL=german.mardones@biobiocode.cl
ZOHO_APP_PASSWORD=
